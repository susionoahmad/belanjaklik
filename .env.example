# ===========================================================
# BelanjAKlik - Environment Variables Template
# ===========================================================
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env
# ===========================================================

# ----------------------------------------------------------
# Supabase (Database & Auth)
# Dapatkan di: https://supabase.com → Project Settings → API
# ----------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------
# Google Gemini Vision API (OCR untuk Screenshot Scanner)
# Dapatkan GRATIS di: https://aistudio.google.com/apikey
# Klik "Create API Key" → Copy → Paste di bawah
# Limit gratis: 15 request/menit, 1500 request/hari
# ----------------------------------------------------------
VITE_GEMINI_API_KEY=AIzaSy...
